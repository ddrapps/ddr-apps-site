{
  "expo": {
    "name": "Guardrail",
    "slug": "guardrail-mvp",
    "scheme": "guardrail",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Guardrail to protect your wallet with location-based spending guardrails.",
          "locationAlwaysPermission": "Allow Guardrail to monitor your danger zones in the background.",
          "locationWhenInUsePermission": "Allow Guardrail to access your location to set up spending guardrails."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0D6E6E"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.guardrail.app",
      "infoPlist": {
        "UIBackgroundModes": ["location", "fetch", "processing"]
      }
    },
    "android": {
      "package": "com.guardrail.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
